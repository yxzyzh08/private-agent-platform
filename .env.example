# Anthropic API Key (Claude models via LiteLLM)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# GitHub Personal Access Token (Issue/PR operations)
GITHUB_TOKEN=ghp_xxxxx

# GitHub Webhook Secret (webhook signature verification)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Redis URL (event bus backend)
REDIS_URL=redis://localhost:6379/0

# ntfy Topic (push notifications for dev bot tasks)
NTFY_TOPIC=my-agent-platform

# Optional: Override log level (DEBUG/INFO/WARNING/ERROR)
# LOG_LEVEL=INFO

# Optional: Override log format (text/json)
# LOG_FORMAT=text
